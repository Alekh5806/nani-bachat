    fontSize: FONTS.xs,
    fontWeight: '600',
    color: COLORS.profit,
  },
  divFooter: {
    flexDirection: 'row',
    justifyContent: 'space-between',
    marginTop: SPACING.md,
    paddingTop: SPACING.md,
    borderTopWidth: 1,
    borderTopColor: COLORS.divider,
  },
  divDate: {
    fontSize: FONTS.xs,
    color: COLORS.textMuted,
